<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TCK Compliance Report — {{ report.implementation }}</title>
    <style>
        :root {
            --neo4j-blue: #018BFF;
            --bronze: #F97316;
            --silver: #22C55E;
            --gold: #6366F1;
            --pass: #22C55E;
            --fail: #EF4444;
            --skip: #9CA3AF;
            --bg: #0F172A;
            --surface: #1E293B;
            --text: #F8FAFC;
            --text-muted: #94A3B8;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
            padding: 2rem;
        }
        .container { max-width: 960px; margin: 0 auto; }
        h1 { font-size: 1.75rem; margin-bottom: 0.25rem; }
        h2 { font-size: 1.25rem; margin: 2rem 0 1rem; color: var(--text-muted); }
        .meta { color: var(--text-muted); font-size: 0.875rem; margin-bottom: 2rem; }

        .badge {
            display: inline-block;
            padding: 0.375rem 1rem;
            border-radius: 9999px;
            font-weight: 600;
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .badge-bronze { background: var(--bronze); color: #fff; }
        .badge-silver { background: var(--silver); color: #fff; }
        .badge-gold { background: var(--gold); color: #fff; }
        .badge-none { background: var(--fail); color: #fff; }

        .tier-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 2rem;
        }
        .tier-card {
            background: var(--surface);
            border-radius: 0.75rem;
            padding: 1.25rem;
            border: 1px solid transparent;
        }
        .tier-card.achieved { border-color: var(--pass); }
        .tier-card h3 { font-size: 1rem; margin-bottom: 0.5rem; }
        .tier-card .stats { font-size: 2rem; font-weight: 700; }
        .tier-card .label { color: var(--text-muted); font-size: 0.75rem; }
        .tier-card .status { margin-top: 0.5rem; font-weight: 600; }
        .status-pass { color: var(--pass); }
        .status-fail { color: var(--fail); }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--surface);
            border-radius: 0.75rem;
            overflow: hidden;
        }
        th, td { padding: 0.625rem 1rem; text-align: left; }
        th {
            background: rgba(255,255,255,0.05);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
        }
        td { font-size: 0.875rem; border-top: 1px solid rgba(255,255,255,0.05); }
        .outcome-passed { color: var(--pass); }
        .outcome-failed { color: var(--fail); }
        .outcome-skipped { color: var(--skip); }
        .footer {
            margin-top: 3rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.75rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>TCK Compliance Report</h1>
        <div class="meta">
            <strong>{{ report.implementation }}</strong> v{{ report.version }}
            &middot; TCK v{{ report.tck_version }}
            &middot; {{ report.timestamp[:10] }}
        </div>

        <div style="margin-bottom: 2rem;">
            Tier Achieved:
            {% if report.tier_achieved == 'gold' %}
                <span class="badge badge-gold">Gold</span>
            {% elif report.tier_achieved == 'silver' %}
                <span class="badge badge-silver">Silver</span>
            {% elif report.tier_achieved == 'bronze' %}
                <span class="badge badge-bronze">Bronze</span>
            {% else %}
                <span class="badge badge-none">Not Certified</span>
            {% endif %}
        </div>

        <h2>Tier Results</h2>
        <div class="tier-grid">
            {% for tier_name in ['bronze', 'silver', 'gold'] %}
            {% set r = report.tiers[tier_name] %}
            <div class="tier-card {{ 'achieved' if r.status == 'PASS' else '' }}">
                <h3>{{ tiers[tier_name].name }}</h3>
                <div class="stats">{{ r.passed }}/{{ r.total }}</div>
                <div class="label">tests passed</div>
                <div class="status {{ 'status-pass' if r.status == 'PASS' else 'status-fail' }}">
                    {{ r.status }}
                </div>
            </div>
            {% endfor %}
        </div>

        <h2>Test Details</h2>
        <table>
            <thead>
                <tr>
                    <th>Test</th>
                    <th>Tier</th>
                    <th>Outcome</th>
                    <th>Duration</th>
                </tr>
            </thead>
            <tbody>
                {% for test in report.tests %}
                <tr>
                    <td>{{ test.nodeid }}</td>
                    <td>{{ test.tier or '—' }}</td>
                    <td class="outcome-{{ test.outcome }}">{{ test.outcome }}</td>
                    <td>{{ '%.3f' | format(test.duration) }}s</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        <div class="footer">
            Generated by neo4j-agent-memory-tck v{{ report.tck_version }}
        </div>
    </div>
</body>
</html>
