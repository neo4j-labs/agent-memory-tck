# Sample environment file for local e2e testing.
# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# All five client e2e suites read these variables from a `.env` file at
# the repo root (loaded by dotenv equivalents in each language) or from
# environment variables (used by GitHub Actions via the MEMORY_API_KEY
# repo secret).

# Hosted Neo4j Agent Memory Service endpoint.
MEMORY_ENDPOINT=https://memory.neo4jlabs.com/v1

# `nams_*` API key generated from https://memory.neo4jlabs.com/dashboard.
# E2E tests skip gracefully when this is empty.
MEMORY_API_KEY=

# Optional: override the user_id used by e2e tests. Default: tck-e2e-<lang>.
# MEMORY_E2E_USER_ID=tck-e2e

# Optional: OpenAI API key for the demo agents (Lenny, Scout, Atlas).
# Not required by the client e2e tests.
# OPENAI_API_KEY=
