# Neo4j Agent Memory Service. If MEMORY_API_KEY is unset, spool runs in
# stub-by-default mode: canned conversation, canned reasoning trace, no
# real NAMS calls. Set MEMORY_API_KEY to flip to live mode.
MEMORY_API_KEY=

# Strands needs a model provider when running in live mode. Set ONE of:
#   - OPENAI_API_KEY  → uses gpt-4o-mini via Strands' OpenAI model
#   - AWS_REGION + AWS credentials → Bedrock mode (uncomment in app/api/chat/route.ts)
# If neither is set, the API route falls back to a stub model that returns
# canned responses regardless of MEMORY_API_KEY.
OPENAI_API_KEY=
